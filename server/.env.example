# ============================================================
# CineVision Server — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cinevision

# Authentication
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# AWS S3 (Script Storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# AI Script Parsing (Google Gemini)
GEMINI_API_KEY=your-gemini-api-key-here
AI_MODEL=gemini-2.0-flash

# CORS — origin(s) allowed to call this API
CLIENT_URL=http://localhost:5173
