# ============================================================
# CineVision Server — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cinevision

# Authentication
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Cloudinary (Asset Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AI Script Parsing (Google Gemini)
GEMINI_API_KEY=your-gemini-api-key-here
AI_MODEL=gemini-2.0-flash

# CORS — origin(s) allowed to call this API
CLIENT_URL=http://localhost:5173
