# Files/folders to exclude when Docker builds the client image.

# Development artifacts (Vite outputs to dist/ — that's what we want to keep,
# but node_modules must be reinstalled fresh inside the builder stage)
node_modules
dist

# Secrets
.env
.env.*
.env.local

# Version control
.git
.gitignore

# IDE / OS
.vscode
.idea
*.DS_Store
Thumbs.db

# Docker files themselves
Dockerfile
.dockerignore

# Logs
*.log
npm-debug.log*

# Test files
coverage
